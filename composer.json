{
    "name": "freeworld/php-jobspy",
    "description": "A PHP library to scrape job listings from various boards, inspired by python-jobspy.",
    "type": "library",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Freeworld\\PhpJobspy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Freeworld\\PhpJobspy\\Tests\\": "tests/"
        }
    }
}
