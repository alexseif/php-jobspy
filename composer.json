{
    "name": "freeworld/php-jobspy",
    "description": "A PHP library to scrape job listings from various boards, inspired by python-jobspy.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alex Seif",
            "email": "alex.seif@gmail.com",
            "homepage": "https://alexseif.com"
        }
    ],
    "require": {
        "php": "^8.2 || ^8.3",
        "guzzlehttp/guzzle": "^7.12",
        "symfony/http-client": "*",
        "symfony/dom-crawler": "*",
        "symfony/css-selector": "*",
        "symfony/panther": "^2.4",
        "dbrekelmans/bdi": "^1.4",
        "symfony/yaml": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Freeworld\\PhpJobspy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Freeworld\\PhpJobspy\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests/"
    }
}
